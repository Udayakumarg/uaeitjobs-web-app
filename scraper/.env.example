# URL of the uaeitjobs backend API
BACKEND_URL=https://uaeitjobs.com

# Admin credentials (must be an admin account)
ADMIN_EMAIL=superadmin@uaeitjobs.com
ADMIN_PASSWORD=Admin@2025

# Browser visibility: true = show browser window (local dev), false = headless (VPS)
HEADED=false

# Max pages to scrape per search term (each page ~20 jobs)
MAX_PAGES=3

# Comma-separated list of sources to run. Omit to run all.
# SOURCES=bayt,naukrigulf
